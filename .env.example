# ============================================================
# Micracode — root .env template
# Copy to `apps/api/.env` (the FastAPI service reads from there,
# and also from this file at repo root if present).
#
# The Next.js app picks up NEXT_PUBLIC_* vars from process env
# at build/dev time; no database or auth credentials required.
# ============================================================

# ---------- Shared ----------
APP_WEB_ORIGIN=http://localhost:3000

# ---------- Next.js (apps/web) ----------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ---------- FastAPI (apps/api) ----------
# LLM provider: `gemini` (default), `openai`, or `ollama`.
LLM_PROVIDER=gemini

# Gemini (used when LLM_PROVIDER=gemini)
GOOGLE_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_MODEL=gpt-5.4
# Optional: override OpenAI endpoint for OpenAI-compatible providers
# (Azure OpenAI proxy, OpenRouter, LiteLLM, vLLM, LM Studio, Together, Groq, …).
# Leave unset to use the default https://api.openai.com/v1
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Ollama (used when LLM_PROVIDER=ollama — no API key required)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Where generated projects live on disk. Defaults to ~/opener-apps.
# Override only for tests or when running from a sandbox.
# OPENER_APPS_DIR=/absolute/path/to/opener-apps

# Logging
LOG_LEVEL=INFO
